    "update:pack": "node --import tsx ./scripts/update-pack.ts",
    "verify:pack-health": "node --import tsx ./scripts/verify-pack-health.ts",
    "diagnose:crosswalk-gaps": "node --import tsx ./scripts/diagnose-crosswalk-gaps.ts",
    "inference:precision": "node --import tsx ./scripts/inference-precision.ts",
    "flows:ingest": "node --import tsx ./scripts/ingest-flows.ts",
