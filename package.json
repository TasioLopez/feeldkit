    "flows:rollback": "node --import tsx ./scripts/flows-rollback.ts",
    "promotion:metrics": "node --import tsx ./scripts/promotion-metrics.ts",
    "promote:rollup": "node --import tsx ./scripts/promote-rollup.ts",
    "process:enrichment-jobs": "node --import tsx ./scripts/process-enrichment-jobs.ts",
    "export:pack": "node --import tsx ./scripts/export-pack.ts",
    "docs:openapi-check": "node --import tsx ./scripts/check-openapi.ts",
    "profile:export": "node --import tsx ./scripts/profile-export.ts",
