{
  "name": "@feeldkit/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript/JavaScript client for the FeeldKit Mapping Intelligence API.",
  "license": "MIT",
  "homepage": "https://feeldkit.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/feeldkit/feeldkit.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "feeldkit",
    "mapping",
    "normalization",
    "crosswalk",
    "industry",
    "geo",
    "crm",
    "linkedin",
    "hubspot",
    "data-mapping"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
